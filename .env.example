# Admin-Dashboard/.env.local.example
# Part 31 — Admin Dashboard Environment Variables
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# NEVER prefix SUPABASE_SERVICE_ROLE_KEY with NEXT_PUBLIC_ ← security risk!

# ── Supabase (public — safe for browser) ──────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Get from: Supabase Dashboard → Settings → API → anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase (SECRET — server-side only, never expose to browser) ─────────────
# Get from: Supabase Dashboard → Settings → API → service_role key
# This bypasses all RLS — keep it secret!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Optional: Extra security token ────────────────────────────────────────────
# Set this to any random string for an extra layer of API protection.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=replace-with-random-32-char-string
